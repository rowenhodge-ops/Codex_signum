# Codex Signum — Environment Variables
# Copy this file to .env and fill in your keys.
# .env is gitignored and must never be committed.

# Required — Anthropic API key for Claude models
ANTHROPIC_API_KEY=sk-ant-...

# Required — GCP project ID for Vertex AI (Gemini + Mistral)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Optional — Google API key (for non-Vertex Gemini access)
GOOGLE_API_KEY=

# Optional — OpenRouter API key (for additional model access)
OPENROUTER_API_KEY=

# Vertex AI authentication is handled via gcloud ADC, not an env var.
# Run: gcloud auth application-default login
