#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

echo "🚀 Running pre-push checks..."
echo ""

# Run type check
echo "📝 Type checking..."
npm run typecheck
TYPECHECK_EXIT_CODE=$?

if [ $TYPECHECK_EXIT_CODE -ne 0 ]; then
  echo ""
  echo "❌ Type check failed!"
  echo ""
  echo "Fix type errors and try again:"
  echo "  - npm run typecheck"
  echo ""
  exit $TYPECHECK_EXIT_CODE
fi

echo "✅ Type check passed!"
echo ""
echo "✅ All pre-push checks passed! Pushing..."
echo ""
