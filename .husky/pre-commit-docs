#!/bin/sh
# Pre-commit hook for documentation validation
# Runs BEFORE code linting to catch doc issues early

echo "📚 Validating documentation structure..."
echo ""

# 1. Check folder structure (no forbidden folders)
node scripts/enforce-folder-structure.js
FOLDER_EXIT=$?

if [ $FOLDER_EXIT -ne 0 ]; then
  echo ""
  echo "❌ Folder structure validation failed!"
  echo ""
  exit $FOLDER_EXIT
fi

# 2. Check task numbering (no duplicates)
node scripts/validate-task-numbers.js
TASK_EXIT=$?

if [ $TASK_EXIT -ne 0 ]; then
  echo ""
  echo "❌ Task numbering validation failed!"
  echo ""
  exit $TASK_EXIT
fi

# 3. Check baseline mutations (no locked doc changes)
node scripts/check-baseline-mutations.js
BASELINE_EXIT=$?

if [ $BASELINE_EXIT -ne 0 ]; then
  echo ""
  echo "❌ Baseline mutation detected!"
  echo ""
  exit $BASELINE_EXIT
fi

echo ""
echo "✅ Documentation validation passed!"
echo ""
